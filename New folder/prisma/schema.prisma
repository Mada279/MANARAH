generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  charity
  waqf
  school
  academy
  mosque
  community_center
  initiative
  other
}

enum RecordStatus {
  active
  inactive
  pending
  archived
}

enum ProgramStatus {
  draft
  active
  paused
  completed
  archived
}

enum BeneficiaryStatus {
  active
  follow_up
  completed
  archived
}

enum VolunteerStatus {
  available
  assigned
  inactive
  archived
}

enum ReportStatus {
  draft
  generated
  reviewed
  published
  archived
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  status       RecordStatus @default(active)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships        OrganizationMember[]
  managedPrograms    Program[]              @relation("ProgramManager")
  uploadedDocuments  Document[]             @relation("DocumentUploader")
  metricValues       ImpactMetricValue[]    @relation("MetricRecorder")
  generatedReports   ImpactReport[]         @relation("ReportGenerator")
  auditLogs          AuditLog[]             @relation("AuditActor")
  notifications      Notification[]

  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  type        OrganizationType @default(other)
  country     String?
  city        String?
  description String?
  logoUrl     String?  @map("logo_url")
  status      RecordStatus @default(active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members       OrganizationMember[]
  roles         Role[]
  programs      Program[]
  beneficiaries Beneficiary[]
  volunteers    Volunteer[]
  documents     Document[]
  metrics       ImpactMetric[]
  reports       ImpactReport[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  roleId         String?      @map("role_id")
  status         RecordStatus @default(active)
  joinedAt       DateTime     @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Role {
  id             String  @id @default(uuid())
  organizationId String? @map("organization_id")
  name           String
  description    String?
  isSystem       Boolean @default(false) @map("is_system")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]
  permissions  RolePermission[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  key         String @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Program {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  name           String
  description    String?
  category       String?
  status         ProgramStatus @default(draft)
  startDate      DateTime?     @map("start_date")
  endDate        DateTime?     @map("end_date")
  managerId      String?       @map("manager_id")
  budgetEstimate Decimal?      @map("budget_estimate") @db.Decimal(14, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager       User?         @relation("ProgramManager", fields: [managerId], references: [id], onDelete: SetNull)
  beneficiaries Beneficiary[]
  volunteers    Volunteer[]
  documents     Document[]
  metrics       ImpactMetric[]
  reports       ImpactReport[]

  @@index([organizationId, status])
  @@map("programs")
}

model Beneficiary {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  programId      String?           @map("program_id")
  name           String
  gender         String?
  ageGroup       String?           @map("age_group")
  phone          String?
  city           String?
  status         BeneficiaryStatus @default(active)
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([organizationId, programId])
  @@map("beneficiaries")
}

model Volunteer {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  programId      String?         @map("program_id")
  name           String
  email          String?
  phone          String?
  skills         String[]        @default([])
  totalHours     Int             @default(0) @map("total_hours")
  status         VolunteerStatus @default(available)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([organizationId, programId])
  @@map("volunteers")
}

model Document {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  programId      String?  @map("program_id")
  uploadedById   String?  @map("uploaded_by")
  title          String
  fileUrl        String   @map("file_url")
  fileType       String?  @map("file_type")
  category       String?
  visibility     String   @default("organization")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  uploadedBy   User?        @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId, programId])
  @@map("documents")
}

model ImpactMetric {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  programId      String?  @map("program_id")
  name           String
  key            String
  unit           String?
  description    String?
  targetValue    Decimal? @map("target_value") @db.Decimal(14, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?            @relation(fields: [programId], references: [id], onDelete: SetNull)
  values       ImpactMetricValue[]

  @@unique([organizationId, programId, key])
  @@map("impact_metrics")
}

model ImpactMetricValue {
  id          String   @id @default(uuid())
  metricId    String   @map("metric_id")
  value       Decimal  @db.Decimal(14, 2)
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  recordedById String? @map("recorded_by")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  metric     ImpactMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  recordedBy User?        @relation("MetricRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([metricId, periodStart, periodEnd])
  @@map("impact_metric_values")
}

model ImpactReport {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  programId      String?      @map("program_id")
  title          String
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  summary        String?
  generatedById  String?      @map("generated_by")
  status         ReportStatus @default(draft)
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  generatedBy  User?        @relation("ReportGenerator", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([organizationId, programId])
  @@map("impact_reports")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor       User?          @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String?  @map("organization_id")
  title          String
  body           String
  type           String   @default("info")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}
